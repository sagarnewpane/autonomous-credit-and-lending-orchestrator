{
  "info": {
    "_postman_id": "credit-lending-api",
    "name": "Autonomous Credit & Lending Orchestrator",
    "description": "API collection for credit scoring and lending system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "testUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testApplicationId",
      "value": "",
      "type": "string"
    }
  ],
  "environments": [
    {
      "id": "local-dev",
      "name": "Local Development",
      "values": [
        {
          "key": "baseUrl",
          "value": "http://localhost:8000",
          "enabled": true
        }
      ]
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/loan/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "loan", ""]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVars.set('accessToken', body.access_token);",
                  "  pm.collectionVars.set('refreshToken', body.refresh_token);",
                  "  pm.collectionVars.set('testUserId', String(body.user.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "signup"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securepassword123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVars.set('accessToken', body.access_token);",
                  "  pm.collectionVars.set('refreshToken', body.refresh_token);",
                  "  pm.collectionVars.set('testUserId', String(body.user.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securepassword123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVars.set('accessToken', body.access_token);",
                  "  pm.collectionVars.set('refreshToken', body.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVars.set('accessToken', '');",
                  "pm.collectionVars.set('refreshToken', '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVars.set('accessToken', body.access_token);",
                  "  pm.collectionVars.set('refreshToken', body.refresh_token);",
                  "  pm.collectionVars.set('testUserId', String(body.user.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"adminpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Loan",
      "item": [
        {
          "name": "Apply for Loan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body && body.application_id) {",
                  "    pm.collectionVars.set('testApplicationId', body.application_id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/loan/apply",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "loan", "apply"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "applicant_name",
                  "value": "John Doe",
                  "type": "text"
                },
                {
                  "key": "user_id",
                  "value": "{{testUserId}}",
                  "type": "text"
                },
                {
                  "key": "loan_amount",
                  "value": "500000",
                  "type": "text"
                },
                {
                  "key": "loan_purpose",
                  "value": "Home Renovation",
                  "type": "text"
                },
                {
                  "key": "tenure_months",
                  "value": "24",
                  "type": "text"
                },
                {
                  "key": "monthly_income",
                  "value": "80000",
                  "type": "text"
                },
                {
                  "key": "monthly_debt",
                  "value": "15000",
                  "type": "text"
                },
                {
                  "key": "collateral_type",
                  "value": "1.0",
                  "type": "text"
                },
                {
                  "key": "cooperative_member",
                  "value": "true",
                  "type": "text"
                }
              ]
            }
          }
        },
        {
          "name": "Get Loan Decision",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/loan/decision/{{testApplicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "loan", "decision", "{{testApplicationId}}"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "Explain Loan Decision",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/loan/explain/{{testApplicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "loan", "explain", "{{testApplicationId}}"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "Re-upload Documents",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/v1/loan/docs/{{testApplicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "loan", "docs", "{{testApplicationId}}"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": "/path/to/your/document.pdf"
                }
              ]
            }
          }
        },
        {
          "name": "Get User Loan History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/loan/user/{{testUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "loan", "user", "{{testUserId}}"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "Get Compliance References",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/loan/compliance/references/{{testApplicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "loan", "compliance", "references", "{{testApplicationId}}"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Loans",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/loans",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "loans"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Admin Review Loan",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/review/{{testApplicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "review", "{{testApplicationId}}"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_status\": \"approved\",\n  \"admin_notes\": \"Verified all documents. Applicant qualifies.\",\n  \"reviewed_by\": \"admin@example.com\"\n}"
            }
          }
        },
        {
          "name": "Get Audit Trail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/audit/{{testApplicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "audit", "{{testApplicationId}}"]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
